<!-- 
  Shopify Push Notification Popup
  Add this code to your Shopify theme: 
  1. Go to: Online Store > Themes > Edit Code
  2. Open: Sections > theme.liquid (or footer.liquid)
  3. Paste this code before </body> tag
-->

<!-- Push Notification Popup Styles -->
<style>
  .push-notification-popup {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 20px 25px;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    z-index: 99999;
    max-width: 350px;
    animation: slideIn 0.5s ease-out;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .push-notification-popup.hidden {
    display: none;
  }

  @keyframes slideIn {
    from {
      transform: translateY(100px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .push-popup-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .push-popup-icon {
    font-size: 32px;
  }

  .push-popup-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0;
  }

  .push-popup-message {
    font-size: 14px;
    margin: 0 0 15px 0;
    opacity: 0.95;
    line-height: 1.5;
  }

  .push-popup-buttons {
    display: flex;
    gap: 10px;
  }

  .push-popup-btn {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
  }

  .push-popup-btn-allow {
    background: white;
    color: #667eea;
  }

  .push-popup-btn-allow:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(255, 255, 255, 0.3);
  }

  .push-popup-btn-later {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }

  .push-popup-btn-later:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .push-popup-close {
    position: absolute;
    top: 10px;
    right: 10px;
    background: none;
    border: none;
    color: white;
    font-size: 20px;
    cursor: pointer;
    opacity: 0.7;
    padding: 5px;
  }

  .push-popup-close:hover {
    opacity: 1;
  }

  /* Mobile Responsive */
  @media (max-width: 480px) {
    .push-notification-popup {
      bottom: 10px;
      right: 10px;
      left: 10px;
      max-width: none;
    }
  }
</style>

<!-- Push Notification Popup HTML -->
<div id="pushNotificationPopup" class="push-notification-popup hidden">
  <button class="push-popup-close" onclick="closePushPopup()">×</button>
  
  <div class="push-popup-header">
    <div class="push-popup-icon">🔔</div>
    <h3 class="push-popup-title">Stay Updated!</h3>
  </div>
  
  <p class="push-popup-message">
    Get instant notifications about new products, exclusive offers, and order updates!
  </p>
  
  <div class="push-popup-buttons">
    <button class="push-popup-btn push-popup-btn-allow" onclick="allowPushNotifications()">
      ✓ Allow
    </button>
    <button class="push-popup-btn push-popup-btn-later" onclick="laterPushNotifications()">
      Maybe Later
    </button>
  </div>
</div>

<!-- Push Notification Script -->
<script src="{{ 'push-notification-helper.js' | asset_url }}" defer></script>

<script>
  // Show popup after 5 seconds if user hasn't subscribed
  setTimeout(() => {
    const isSubscribed = localStorage.getItem('pushNotificationSubscribed');
    const popupDismissed = localStorage.getItem('pushPopupDismissed');
    
    if (!isSubscribed && !popupDismissed) {
      document.getElementById('pushNotificationPopup').classList.remove('hidden');
    }
  }, 5000); // Show after 5 seconds

  // Allow notifications
  async function allowPushNotifications() {
    document.getElementById('pushNotificationPopup').classList.add('hidden');
    
    // Call the subscription function from push-notification-helper.js
    if (window.PushNotifications && window.PushNotifications.subscribe) {
      await window.PushNotifications.subscribe();
    } else {
      console.error('Push notification helper not loaded');
      alert('Error: Push notification system not ready. Please refresh the page.');
    }
  }

  // Dismiss popup for later
  function laterPushNotifications() {
    document.getElementById('pushNotificationPopup').classList.add('hidden');
    localStorage.setItem('pushPopupDismissed', 'true');
    
    // Show again after 24 hours
    setTimeout(() => {
      localStorage.removeItem('pushPopupDismissed');
    }, 24 * 60 * 60 * 1000);
  }

  // Close popup permanently
  function closePushPopup() {
    document.getElementById('pushNotificationPopup').classList.add('hidden');
    localStorage.setItem('pushPopupDismissed', 'true');
  }
</script>
